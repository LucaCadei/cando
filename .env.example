# Copia in .env e modifica i valori prima di avviare in produzione.

# Password del database PostgreSQL
DB_PASSWORD=cando-dev-password

# Chiave segreta per la firma dei JWT — deve essere lunga e casuale in produzione
JWT_SECRET=cando-dev-secret-change-in-prod

# Chiave per l'endpoint admin /concepts (POST/DELETE)
ADMIN_KEY=dev-key-insecure

# URL del backend accessibile dal browser (non dall'interno del container)
VITE_API_URL=http://localhost:8000

# Origini CORS consentite (separare più origini con virgola)
CORS_ORIGIN=http://localhost

# Parametri per il job di popolamento catalogo (usati da Cloud Run Jobs o docker compose run)
POPULATE_QUERY=
POPULATE_TYPE=
POPULATE_COUNT=10
POPULATE_PRICE=200
POPULATE_LANG=it
POPULATE_UNLISTED=false
